{
  "schemaVersion": 5,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-assets",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    },
    "connectivityPlane": {
      "allowed": [
        "application",
        "platform"
      ]
    },
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "desktopBuildProfileId": "standalone.production"
  },
  "profileFiles": {
    "standalone.development": "configs/topology/standalone.development.env",
    "cloud.development": "configs/topology/cloud.development.env",
    "cloud.production": "configs/topology/cloud.production.env",
    "standalone.production": "configs/topology/standalone.production.env"
  },
  "envKeys": {
    "deploymentProfile": "SDKWORK_ASSETS_DEPLOYMENT_PROFILE",
    "clientDeploymentProfile": "VITE_SDKWORK_ASSETS_DEPLOYMENT_PROFILE",
    "apiGatewayBaseUrl": "SDKWORK_ASSETS_PLATFORM_API_GATEWAY_HTTP_URL",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_ASSETS_PLATFORM_API_GATEWAY_HTTP_URL",
    "clientApplicationPublicHttpUrl": "VITE_SDKWORK_ASSETS_APPLICATION_PUBLIC_HTTP_URL"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_ASSETS_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_ASSETS_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_ASSETS_APPLICATION_PUBLIC_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_ASSETS_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_ASSETS_PLATFORM_API_GATEWAY_HTTP_URL"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "web-renderer",
            "package": "sdkwork-assets-pc-react",
            "script": "dev",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": []
      },
      "cloud.development": {
        "processes": [],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "cloud.production": {
        "processes": [
          {
            "id": "web-renderer",
            "package": "sdkwork-assets-pc-react",
            "script": "build",
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": [
          "platform.api-gateway"
        ]
      },
      "standalone.production": {
        "processes": [
          {
            "id": "web-renderer",
            "package": "sdkwork-assets-pc-react",
            "script": "dev",
            "required": true,
            "role": "client"
          }
        ],
        "healthSurfaces": []
      }
    }
  },
  "packaging": {
    "targets": [
      {
        "id": "web-browser-static",
        "profile": "cloud.split-services.production",
        "platform": "web",
        "architecture": "any",
        "formats": [
          "static"
        ]
      }
    ],
    "cloudConfigFiles": []
  },
  "cloudPublicHosts": {
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "components": {}
}
