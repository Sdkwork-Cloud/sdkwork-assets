VITE_SDKWORK_ASSETS_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_ASSETS_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:4180
VITE_SDKWORK_ASSETS_DEPLOYMENT_PROFILE=standalone
VITE_APP_ENV=development

# IAM integration (optional overrides; defaults to dev/local)
VITE_SDKWORK_ASSETS_IAM_ENVIRONMENT=dev
VITE_SDKWORK_DEPLOYMENT_MODE=local
# Production default enforces login; set false for local UI-only dev
VITE_SDKWORK_ASSETS_IAM_REQUIRED=false

# Dev-only login prefill (never set in production builds)
# VITE_SDKWORK_ASSETS_AUTH_DEV_EMAIL=
# VITE_SDKWORK_ASSETS_AUTH_DEV_PASSWORD=

# Compatibility aliases consumed by auth runtime
VITE_SDKWORK_APPBASE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_SDKWORK_IAM_APP_API_BASE_URL=http://127.0.0.1:3900

# SDKWork private bootstrap credential (blank in tracked files).
SDKWORK_ACCESS_TOKEN=
