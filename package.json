{
  "license": "AGPL-3.0-or-later",
  "name": "@sdkwork/assets-root",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@sdkwork/app-topology": "workspace:*"
  },
  "scripts": {
    "stop": "pnpm exec sdkwork-app stop",
    "dev": "pnpm dev:standalone",
    "build": "pnpm exec sdkwork-app build",
    "typecheck": "pnpm --filter @sdkwork/assets-pc-react typecheck",
    "test": "pnpm exec sdkwork-app test",
    "check": "pnpm exec sdkwork-app check",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "verify": "pnpm exec sdkwork-app verify",
    "clean": "pnpm exec sdkwork-app clean",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:test": "node --test tests/repository-structure.test.mjs tests/architecture-alignment.test.mjs",
    "topology:verify": "pnpm topology:validate && pnpm topology:test",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "_sdkwork:build": "pnpm --filter @sdkwork/assets-pc-react build",
    "_sdkwork:test": "pnpm --filter @sdkwork/assets-pc-react test",
    "_sdkwork:check": "pnpm topology:verify && pnpm check:app-composition && cargo test --workspace && pnpm --filter @sdkwork/assets-core test && node --test tests/repository-structure.test.mjs tests/architecture-alignment.test.mjs tests/platform-contracts.test.mjs tests/cross-repo-media-alignment.test.mjs tests/drive-openapi-alignment.test.mjs",
    "_sdkwork:verify": "pnpm check && pnpm --filter @sdkwork/assets-pc-react verify",
    "_sdkwork:clean": "pnpm --filter @sdkwork/assets-pc-react clean",
    "dev:standalone": "pnpm exec sdkwork-app dev --deployment-profile standalone",
    "dev:cloud": "pnpm exec sdkwork-app dev --deployment-profile cloud",
    "api:assembly:materialize": "node ../sdkwork-specs/tools/materialize-api-assembly.mjs --root .",
    "api:assembly:validate": "node ../sdkwork-specs/tools/validate-api-assembly.mjs --root ."
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@sdkwork/iam-app-sdk"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
